{
  "version": "0.1",
  "defaults": {
    "cwd": ".",
    "stdout": "logs/${asset}.out",
    "stderr": "logs/${asset}.err",
    "env": {
      "prepend": {
        "lib_path": [
          "/usr/local/hakoniwa/lib"
        ],
        "PATH": ["/usr/local/hakoniwa/bin"] 
      }
    },    
    "start_grace_sec": 1,
    "delay_sec": 3
  },
  "assets": [
    {
      "name": "tb3_sim",
      "activation_timing": "before_start",
      "command": "./src/cmake-build/main_for_sample/tb3/tb3_sim ",
      "args": [
        "config/sensors/lidar/urg-04lx-ug01.json"
      ],
      "cwd": "."
    },
    {
      "name": "gamepad",
      "activation_timing": "before_start",
      "command": "/Users/tmori/.pyenv/versions/3.12.3/bin/python",
      "args": [
        "python/tb3_gamepad.py"
      ],
      "cwd": "."
    }    
  ],
  "notify": {
    "type": "exec",
    "command": "scripts/notify_on_fail.sh",
    "args": ["${asset}", "asset_exit", "${timestamp}"]
  }
}