{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hakoniwa.dev/schemas/gps.schema.json",
  "title": "Hakoniwa GPS sensor profile",
  "description": "SDF-like but MJCF-resolved JSON config for GPS sensor profiles used by Hakoniwa MuJoCo sensors.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "spec",
    "mjcf_binding",
    "pdu_config"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "spec": {
      "$ref": "#/$defs/spec"
    },
    "mjcf_binding": {
      "$ref": "#/$defs/mjcfBinding"
    },
    "pdu_config": {
      "$ref": "#/$defs/pduConfig"
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "name",
        "frame_id",
        "update_rate_hz"
      ],
      "properties": {
        "type": {
          "const": "gps"
        },
        "name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "frame_id": {
          "$ref": "#/$defs/nonEmptyString",
          "description": "The coordinate frame this sensor is attached to."
        },
        "update_rate_hz": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "The frequency at which the sensor generates data, in Hz."
        },
        "noise": {
          "$ref": "#/$defs/noise"
        }
      }
    },
    "mjcfBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "config_style",
        "runtime_source",
        "source_body"
      ],
      "properties": {
        "config_style": {
          "const": "hakoniwa-sdf-like"
        },
        "runtime_source": {
          "const": "mjcf"
        },
        "source_body": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "pduConfig": {
      "allOf": [
        {
          "$ref": "https://hakoniwa.dev/schemas/component-common.schema.json#/$defs/pduConfig"
        },
        {
          "required": [
            "pdu_name",
            "update_rate_hz"
          ]
        }
      ]
    },
    "noise_model": {
      "type": "object",
      "properties": {
        "type": {
          "enum": ["gaussian"],
          "default": "gaussian"
        },
        "mean": {
          "type": "number",
          "default": 0.0
        },
        "stddev": {
          "type": "number",
          "minimum": 0,
          "default": 0.0
        },
        "bias_mean": {
          "type": "number",
          "default": 0.0
        },
        "bias_stddev": {
          "type": "number",
          "minimum": 0,
          "default": 0.0
        }
      }
    },
    "noise": {
      "type": "object",
      "properties": {
        "position_horizontal": {
          "$ref": "#/$defs/noise_model"
        },
        "position_vertical": {
          "$ref": "#/$defs/noise_model"
        },
        "velocity_horizontal": {
          "$ref": "#/$defs/noise_model"
        },
        "velocity_vertical": {
          "$ref": "#/$defs/noise_model"
        }
      }
    }
  }
}
