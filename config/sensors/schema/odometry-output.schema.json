{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hakoniwa.dev/schemas/odometry-output.schema.json",
  "title": "Hakoniwa Odometry output",
  "allOf": [
    {
      "$ref": "./common-output.schema.json"
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "frame_id",
        "child_frame_id",
        "source_body",
        "mode"
      ],
      "properties": {
        "type": {
          "const": "odometry"
        },
        "frame_id": {
          "type": "string",
          "minLength": 1
        },
        "child_frame_id": {
          "type": "string",
          "minLength": 1
        },
        "source_body": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "enum": [
            "ground_truth",
            "encoder"
          ]
        }
      }
    }
  ]
}
