{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hakoniwa.dev/schemas/rgbd-camera.schema.json",
  "title": "Hakoniwa RGBD Camera sensor profile",
  "description": "SDF-like but MJCF-resolved JSON config for RGBD Camera profiles used by Hakoniwa MuJoCo sensors. This schema composes the standard camera and depth-camera schemas.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "spec",
    "mjcf_binding",
    "pdu_config"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "spec": {
      "$ref": "#/$defs/spec"
    },
    "mjcf_binding": {
      "$ref": "#/$defs/mjcfBinding"
    },
    "pdu_config": {
      "$ref": "#/$defs/pduConfig"
    }
  },
  "$defs": {
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "name",
        "rgb",
        "depth"
      ],
      "properties": {
        "type": {
          "const": "rgbd_camera"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "rgb": {
          "$ref": "camera.schema.json#/$defs/cameraSpec"
        },
        "depth": {
          "$ref": "depth-camera.schema.json#/$defs/depthCameraSpec"
        }
      }
    },
    "mjcfBinding": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "config_style": {
          "const": "hakoniwa-sdf-like"
        },
        "runtime_source": {
          "const": "mjcf"
        },
        "rgb_camera_name": {
          "type": "string",
          "minLength": 1
        },
        "depth_camera_name": {
          "type": "string",
          "minLength": 1
        },
        "body_name": {
          "type": "string",
          "minLength": 1
        },
        "freejoint_name": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "pduConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "streams"
      ],
      "properties": {
        "streams": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/pduStream"
          }
        }
      }
    },
    "pduStream": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "pdu_name",
        "update_rate_hz",
        "message_type"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "pdu_name": {
          "type": "string",
          "minLength": 1
        },
        "update_rate_hz": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "message_type": {
          "const": "sensor_msgs/Image"
        }
      }
    }
  }
}
