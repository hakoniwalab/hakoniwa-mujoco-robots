{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hakoniwa.dev/schemas/tf-output.schema.json",
  "title": "Hakoniwa TF output",
  "allOf": [
    {
      "$ref": "./common-output.schema.json"
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "transforms"
      ],
      "properties": {
        "type": {
          "const": "tf"
        },
        "transforms": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "parent_frame_id",
              "child_frame_id",
              "source_body"
            ],
            "properties": {
              "parent_frame_id": {
                "type": "string",
                "minLength": 1
              },
              "child_frame_id": {
                "type": "string",
                "minLength": 1
              },
              "source_body": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    }
  ]
}
