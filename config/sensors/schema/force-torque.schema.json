{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hakoniwa.dev/schemas/force-torque.schema.json",
  "title": "Hakoniwa Force/Torque sensor profile",
  "description": "SDF-like but MJCF-resolved JSON config for Force/Torque sensor profiles used by Hakoniwa MuJoCo sensors.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "spec",
    "mjcf_binding",
    "pdu_config"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "spec": {
      "$ref": "#/$defs/spec"
    },
    "mjcf_binding": {
      "$ref": "#/$defs/mjcfBinding"
    },
    "pdu_config": {
      "$ref": "#/$defs/pduConfig"
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "name",
        "frame_id",
        "update_rate_hz"
      ],
      "properties": {
        "type": {
          "const": "force_torque"
        },
        "name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "frame_id": {
          "$ref": "#/$defs/nonEmptyString",
          "description": "The coordinate frame this sensor is attached to."
        },
        "update_rate_hz": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "The frequency at which the sensor generates data, in Hz."
        },
        "frame": {
          "enum": ["parent", "child", "sensor"],
          "default": "child",
          "description": "The frame in which the measurements are expressed."
        },
        "measure_direction": {
          "enum": ["parent_to_child", "child_to_parent"],
          "default": "child_to_parent",
          "description": "The direction of the measured force/torque."
        }
      }
    },
    "mjcfBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "config_style",
        "runtime_source",
        "joint_name"
      ],
      "properties": {
        "config_style": {
          "const": "hakoniwa-sdf-like"
        },
        "runtime_source": {
          "const": "mjcf"
        },
        "joint_name": {
          "$ref": "#/$defs/nonEmptyString",
          "description": "The MJCF joint to monitor for forces and torques."
        }
      }
    },
    "pduConfig": {
      "allOf": [
        {
          "$ref": "https://hakoniwa.dev/schemas/component-common.schema.json#/$defs/pduConfig"
        },
        {
          "required": [
            "pdu_name",
            "update_rate_hz"
          ]
        }
      ]
    }
  }
}
