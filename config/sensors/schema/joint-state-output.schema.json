{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hakoniwa.dev/schemas/joint-state-output.schema.json",
  "title": "Hakoniwa JointState output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "spec",
    "mjcf_binding",
    "pdu_config"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "joints"
      ],
      "properties": {
        "type": {
          "const": "joint_state"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "joints": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "mjcf_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "joints"
      ],
      "properties": {
        "joints": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "mjcf_joint"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "mjcf_joint": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "pdu_config": {
      "allOf": [
        {
          "$ref": "https://hakoniwa.dev/schemas/component-common.schema.json#/$defs/requiredPduConfig"
        },
        {
          "properties": {
            "message_type": {
              "const": "sensor_msgs/JointState"
            }
          }
        }
      ]
    }
  }
}
