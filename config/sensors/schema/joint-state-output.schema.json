{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hakoniwa.dev/schemas/joint-state-output.schema.json",
  "title": "Hakoniwa JointState output",
  "allOf": [
    {
      "$ref": "./common-output.schema.json"
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "joints"
      ],
      "properties": {
        "type": {
          "const": "joint_state"
        },
        "joints": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "mjcf_joint"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "mjcf_joint": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    }
  ]
}
