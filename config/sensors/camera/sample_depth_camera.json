{
  "$schema": "../schema/depth-camera.schema.json",
  "spec": {
    "frame_id": "camera_depth_frame",
    "update_rate_hz": 30,
    "horizontal_fov": 1.047,
    "image": {
      "width": 640,
      "height": 480,
      "format": "DEPTH_F32_M"
    },
    "clip": {
      "near": 0.1,
      "far": 10.0
    },
    "noise": {
      "type": "gaussian",
      "mean": 0.0,
      "stddev": 0.01
    }
  },
  "mjcf_binding": {
    "config_style": "hakoniwa-sdf-like",
    "runtime_source": "mjcf",
    "camera_name": "camera_depth"
  },
  "pdu_config": {
    "pdu_name": "camera_depth_image",
    "update_rate_hz": 30,
    "message_type": "sensor_msgs/Image"
  }
}
