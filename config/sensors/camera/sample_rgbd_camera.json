{
  "$schema": "../schema/rgbd-camera.schema.json",
  "rgb": {
    "frame_id": "camera_rgb_frame",
    "update_rate": 30,
    "horizontal_fov": 1.047,
    "image": {
      "width": 640,
      "height": 480,
      "format": "R8G8B8"
    },
    "clip": {
      "near": 0.02,
      "far": 300
    },
    "noise": {
      "type": "gaussian",
      "mean": 0.0,
      "stddev": 0.007
    }
  },
  "depth": {
    "frame_id": "camera_depth_frame",
    "update_rate": 30,
    "horizontal_fov": 1.047,
    "image": {
      "width": 640,
      "height": 480,
      "format": "DEPTH_F32_M"
    },
    "clip": {
      "near": 0.1,
      "far": 10.0
    },
    "noise": {
      "type": "gaussian",
      "mean": 0.0,
      "stddev": 0.01
    }
  }
}
