{
  "$schema": "schema/hakoniwa-asset-manifest.schema.json",
  "name": "tb3_mbody_waffle_asset",
  "description": "TurtleBot3 Waffle asset using the minimal MuJoCo world generated by hakoniwa-mbody-registry.",
  "model": "../../../hakoniwa-mbody-registry/bodies/turtlebot3_waffle/generated/turtlebot3_waffle.minimal_world.xml",
  "pdu_def": "../tb3-pdudef-compact.json",
  "endpoint": "../endpoint/tb3_sim_endpoint.json",
  "components": [
    {
      "id": "left_wheel_actuator",
      "kind": "actuator",
      "type": "joint_actuator",
      "config": "../actuator/joint/tb3_mbody_left_wheel.json"
    },
    {
      "id": "right_wheel_actuator",
      "kind": "actuator",
      "type": "joint_actuator",
      "config": "../actuator/joint/tb3_mbody_right_wheel.json"
    },
    {
      "id": "wheel_joint_states",
      "kind": "state_output",
      "type": "joint_state",
      "config": "../sensors/joint_state/tb3-wheel-joint-states.json",
      "pdu_robot": "TB3"
    },
    {
      "id": "lidar",
      "kind": "sensor",
      "type": "lidar_2d",
      "config": "../sensors/lidar/lds-02.json",
      "pdu_robot": "TB3"
    },
    {
      "id": "imu",
      "kind": "sensor",
      "type": "imu",
      "config": "../sensors/imu/tb3-imu.json",
      "pdu_robot": "TB3"
    },
    {
      "id": "odometry",
      "kind": "state_output",
      "type": "odometry",
      "config": "../sensors/odometry/tb3-ground-truth-odom.json",
      "pdu_robot": "TB3"
    },
    {
      "id": "tf",
      "kind": "state_output",
      "type": "tf",
      "config": "../sensors/tf/tb3-basic-tf.json",
      "pdu_robot": "TB3"
    }
  ]
}
