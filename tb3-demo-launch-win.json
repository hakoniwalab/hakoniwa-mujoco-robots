{
  "version": "0.1",
  "defaults": {
    "cwd": ".",
    "stdout": "logs/${asset}.out",
    "stderr": "logs/${asset}.err",
    "env": {
      "prepend": {
        "lib_path": [
        ],
        "PATH": ["C:\\project\\hakoniwa-core-pro\\build-win\\sources\\command\\Release"],
        "PYTHONPATH": ["C:\\project\\hakoniwa-core-pro\\build-win\\sources\\assets\\bindings\\python\\Release"]
      }
    },    
    "start_grace_sec": 1,
    "delay_sec": 3
  },
  "assets": [
    {
      "name": "tb3_sim",
      "activation_timing": "before_start",
      "command": ".\\build-win\\main_for_sample\\tb3\\Release\\tb3_sim.exe ",
      "args": [
        "config/sensors/lidar/lds-01.json"
      ],
      "cwd": "."
    },
    {
      "name": "gamepad",
      "activation_timing": "before_start",
      "command": "python",
      "args": [
        "python/tb3_gamepad.py"
      ],
      "cwd": "."
    },
    {
      "name": "lidar",
      "activation_timing": "before_start",
      "command": "python",
      "args": [
        "python/tb3_lidar_visualizer.py"
      ],
      "cwd": "."
    },
    {
      "name": "state_visualizer",
      "activation_timing": "before_start",
      "command": "python",
      "args": [
        "python/tb3_state_visualizer.py"
      ],
      "cwd": "."
    }    
  ],
  "notify": {
    "type": "exec",
    "command": "scripts/notify_on_fail.sh",
    "args": ["${asset}", "asset_exit", "${timestamp}"]
  }
}