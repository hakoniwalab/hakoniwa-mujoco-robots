<mujoco model="ultrasonic_test">
  <compiler angle="radian"/>

  <option timestep="0.001" gravity="0 0 -9.81"/>

  <worldbody>
    <geom name="ground" type="plane" size="5 5 0.1" pos="0 0 0"/>

    <body name="base_footprint" pos="0 0 0.1">
      <freejoint name="base_freejoint"/>
      <geom name="base_geom" type="box" size="0.1 0.1 0.05" pos="0 0 0" rgba="0 0.4 1 1"/>

      <!-- Hakoniwa ultrasonic uses local +X as measurement axis -->
      <site name="front_ultrasonic_site"
            pos="0.12 0 0"
            size="0.02"
            rgba="1 0 0 1"/>
    </body>

    <!-- Front wall: expected projected distance roughly 1.0 - 0.12 = 0.88 m -->
    <body name="front_wall" pos="1.0 0 0.1">
      <geom name="front_wall_geom" type="box" size="0.02 0.5 0.5"/>
    </body>

    <!-- Diagonal obstacle for cone ray test -->
    <body name="diag_obstacle" pos="0.8 0.35 0.1">
      <geom name="diag_obstacle_geom" type="box" size="0.05 0.05 0.2"/>
    </body>
  </worldbody>
</mujoco>